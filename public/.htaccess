RewriteEngine On
RewriteBase /perfume-catalog/public/

# Убираем www (по ТЗ)
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ http://%1/$1 [R=301,L]

# Если файл есть реально — отдаём его (картинки, стили)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Всё остальное → отправляем в index.php
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]

# Запрет просмотра папок
Options -Indexes